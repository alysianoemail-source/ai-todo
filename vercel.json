{
  "version": 2,
  "buildCommand": "",
  "installCommand": "",
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/chat.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/chat.js": {
      "memory": 128,
      "maxDuration": 10
    }
  }
}
